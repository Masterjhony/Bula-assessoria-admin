# Porta HTTP do servidor Baileys (atrás do Caddy/Nginx).
PORT=3001

# Multi-inbox: cada sessão Baileys tem sua pasta de auth em ${SESSIONS_DIR}/<id>.
# (NÃO versionar; backup recomendado.)
SESSIONS_DIR=/opt/whatsapp-crm/auth-sessions
# Sessão usada quando o app não informa ?session= (compat: grupos, assessor,
# campanhas, gif-lotes continuam neste número).
DEFAULT_SESSION_ID=joao
# LEGADO (sessão única). Mantido só para adoção automática no 1º boot: se
# SESSIONS_DIR/<default> não existir mas houver creds aqui, são copiadas.
AUTH_DIR=/opt/whatsapp-crm/auth

# URL pública do app Next (admin) — usada pelo webhook de inbound para rodar o
# fluxo do bot e devolver a resposta. Sem isto, a sessão só ENVIA (não responde).
NEXT_API_URL=https://admin.bulaassessoria.com

# Segredo compartilhado com o Next (deve bater com WHATSAPP_GROUP_TASK_SECRET no
# .env.local / Vercel). Protege /api/whatsapp/inbound.
WEBHOOK_SECRET=cole-aqui-o-mesmo-WHATSAPP_GROUP_TASK_SECRET

# Token de acesso aos endpoints HTTP do servidor (porta exposta em IP público).
# Deve bater com WHATSAPP_SERVER_TOKEN no .env.local / Vercel do Next. Sem ele,
# qualquer um na internet poderia enviar mensagens ou ler o QR.
API_TOKEN=cole-aqui-o-mesmo-WHATSAPP_SERVER_TOKEN

# Jitter anti-ban (ms) — atraso ALEATÓRIO entre envios em lote.
MIN_DELAY_MS=8000
MAX_DELAY_MS=25000

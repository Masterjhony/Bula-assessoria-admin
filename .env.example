# Supabase — preencha com os valores do projeto que voce vai criar no dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Meta Ads - painel /adminjmp/analytics
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_2705134163151418
META_BUSINESS_ID=6034968389924192
META_CAMPAIGN_IDS=120247464210140708
META_GRAPH_VERSION=v25.0

# WhatsApp Cloud API - numero oficial da Meta
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_GRAPH_VERSION=v25.0
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=pt_BR
# Webhook de recebimento (API oficial). Configure os dois no painel da Meta:
# WhatsApp > Configuration > Webhook. Callback URL: https://SEU_DOMINIO/api/whatsapp/cloud/webhook
# VERIFY_TOKEN: string livre que voce inventa e cola igual aqui e no painel (handshake do GET).
WHATSAPP_CLOUD_WEBHOOK_VERIFY_TOKEN=
# APP_SECRET: "Chave secreta do app" em developers.facebook.com > App > Configuracoes > Basico.
# Usado para validar a assinatura X-Hub-Signature-256 de cada POST. Sem ele, o webhook aceita sem verificar.
WHATSAPP_CLOUD_APP_SECRET=

# FiscalAPI - consulta de Inscricao Estadual por CPF/UF no CRM
# Gere no dashboard da FiscalAPI: https://app.fiscalapi.com.br
FISCALAPI_API_KEY=
FISCALAPI_BASE_URL=https://api.fiscalapi.com.br
# Padrao economico: false consulta somente a UF do lead. true consulta 27 UFs quando UF estiver ausente.
FISCALAPI_IE_ALL_STATES=false

# Score/protestos ficam separados porque bureaus sao bem mais caros.
# Configure somente quando contratar um provedor de credito.
CREDIT_PROVIDER_URL=
CREDIT_PROVIDER_TOKEN=

# videoextrator (Formula do Boi) - dashboard FastAPI na VPS, usado na pagina
# /sistema/ia/leiloes (Analise de Leiloes). O TOKEN deve ser igual ao
# DASHBOARD_TOKEN configurado no .env da VPS.
VIDEOEXTRATOR_API_URL=http://146.190.68.155:8000
VIDEOEXTRATOR_API_TOKEN=

# OpenRouter - IA do concierge WhatsApp
OPENROUTER_API_KEY=
# Modelo principal do atendimento por IA. O concierge conduz uma conversa
# comercial (le subtexto, reage com repertorio de pecuaria), entao vale um
# modelo de topo: ~1 centavo por resposta. Fallback automatico se falhar.
OPENROUTER_CONCIERGE_MODEL=openai/gpt-5.6-luna
# Ordem opcional de fallback, separada por virgula. Se vazio, usa a lista interna.
OPENROUTER_CONCIERGE_FALLBACK_MODELS=anthropic/claude-sonnet-5,deepseek/deepseek-v4-pro,google/gemini-2.5-flash

# Direct Data - consultas que preenchem o cadastro sozinho (telefone->CPF, CPF+UF->I.E.).
# Sem token, o concierge simplesmente pergunta os dados ao lead.
DIRECTD_TOKEN=

# Secret que o cron da Vercel usa para autenticar o catchup do concierge
# (rede de seguranca: reprocessa lead que ficou sem resposta).
CRON_SECRET=
